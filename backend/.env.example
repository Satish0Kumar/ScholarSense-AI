# ═══════════════════════════════════════════════════════════════════════
# ScholarSense Backend - Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# For Render deployment, add these as Environment Variables in dashboard

# ── Security (REQUIRED) ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_min_32_chars
JWT_SECRET_KEY=your_jwt_secret_key_here_min_32_chars

# ── Database (REQUIRED) ────────────────────────────────────────────────
# For Supabase, get these from: Settings → Database → Connection parameters
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_db_password

# ── Application Settings ───────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=False
JWT_ACCESS_TOKEN_EXPIRES=3600
PROJECT_NAME=ScholarSense

# ── CORS Origins ───────────────────────────────────────────────────────
# Add your Vercel frontend URL here (comma-separated)
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ── Email Service (Optional) ───────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxx

# ── Render Specific (Auto-provided by Render) ──────────────────────────
# PORT=10000  # Render sets this automatically
